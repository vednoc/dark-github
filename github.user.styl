    }

    .underline-dashed { background-image: linear-gradient(to right, bg5 50%, bg0 0%) i }
    .UnderlineNav-item { color: var(--color-menu-heading-text) }

    // Search elements
    .ais {
        &-SearchBox {
            &-input {
                //color: var(--color-text-secondary)
                //border-color: var(--color-border-secondary)
                //background-color: var(--color-bg-primary)
                //box-shadow: var(--color-shadow-small)
                //&:focus { box-shadow: 0 0 0 3px ac5; border-color: ac3 }
                // this nelow recolors search icon when not focus, idk way to invert just icon or replace it when focus too.
                filter: grayscale(1) invert(0.95) brightness(1.2)
                &:focus { box-shadow: 0 0 0 3px ac5; border-color: ac3; filter: none; background-color: bg0; color: fg0  }
